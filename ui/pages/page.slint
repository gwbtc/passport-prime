import { Theme, UISize, ButtonSize, ButtonVariant } from "@ui/theme.slint";
import { Button } from "@ui/button.slint";
import { Navigate } from "../gen/navigate.slint";
import { GwBridge } from "../gw-bridge.slint";
import { Cyber, NeonPanel, MonoText } from "../cyber.slint";

export component MainPagePage inherits Rectangle {
    background: Cyber.page-bg;

    // Index whose delete is awaiting confirmation (-1 = none).
    property <int> confirm-delete: -1;

    // Human label for a src/store.rs::stage value.
    function stage-name(s: int) -> string {
        if (s >= 6) { return "live"; }
        if (s >= 5) { return "attested — broadcast pending"; }
        if (s >= 2) { return "funded — ready to mine"; }
        return "backed up — needs funding";
    }

    VerticalLayout {
        width: parent.width;
        height: parent.height;
        padding-left: 24px;
        padding-right: 24px;
        padding-top: 24px + UISize.control-center-status-bar-height;
        padding-bottom: 24px;
        spacing: 14px;

        MonoText {
            text: "> groundwire";
            color: Cyber.neon;
            font-size: 36px;
            font-weight: 700;
            letter-spacing: 2px;
            horizontal-alignment: left;
        }

        Text {
            text: "Spawn and manage Groundwire identities on your Passport.";
            color: Theme.palette-muted;
            font-family: "Montserrat";
            font-size: 24px;
            font-weight: 500;
            wrap: word-wrap;
        }

        if GwBridge.identities.length == 0: NeonPanel {
            height: 120px;
            VerticalLayout {
                padding: 18px;
                spacing: 8px;
                MonoText {
                    text: "// no identities";
                    color: Cyber.neon;
                    font-size: 26px;
                }
                Text {
                    text: "Create one to get started — your master ticket is generated and stored on the Passport.";
                    color: Theme.palette-muted;
                    font-family: "Montserrat";
                    font-size: 22px;
                    wrap: word-wrap;
                }
            }
        }

        for id[i] in GwBridge.identities: NeonPanel {
            VerticalLayout {
                padding: 16px;
                spacing: 6px;
                MonoText {
                    // Comet @p once attested; otherwise the address-tail label.
                    text: id.comet != "" ? id.comet : "id " + id.label;
                    color: Cyber.neon;
                    font-size: 28px;
                    font-weight: 700;
                }
                MonoText {
                    text: id.address;
                    color: Theme.palette-muted;
                    font-size: 19px;
                }
                MonoText {
                    text: "// " + stage-name(id.stage);
                    color: id.stage >= 6 ? Cyber.neon : Theme.palette-muted;
                    font-size: 19px;
                    letter-spacing: 1px;
                }

                // Delete confirmation replaces the action row when armed.
                if confirm-delete == i: HorizontalLayout {
                    spacing: 8px;
                    MonoText {
                        text: "delete? this erases its backup";
                        color: Theme.palette-danger;
                        font-size: 19px;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                    }
                    Button {
                        size: ButtonSize.sm;
                        variant: ButtonVariant.ghost;
                        text: "No";
                        clicked => { root.confirm-delete = -1; }
                    }
                    Button {
                        size: ButtonSize.sm;
                        variant: ButtonVariant.danger;
                        text: "Delete";
                        clicked => {
                            GwBridge.delete-identity(i);
                            root.confirm-delete = -1;
                        }
                    }
                }
                if confirm-delete != i: HorizontalLayout {
                    spacing: 8px;
                    // Resume is only meaningful before attestation.
                    if id.stage < 5: Button {
                        size: ButtonSize.sm;
                        variant: ButtonVariant.primary;
                        foreground: Cyber.on-neon;
                        text: "Resume";
                        horizontal-stretch: 1;
                        clicked => {
                            GwBridge.pending-resume = GwBridge.load-identity(i);
                            if (GwBridge.pending-resume.ok) {
                                Navigate.create-page({ });
                            }
                        }
                    }
                    Button {
                        size: ButtonSize.sm;
                        variant: ButtonVariant.ghost;
                        text: "Delete";
                        clicked => { root.confirm-delete = i; }
                    }
                }
            }
        }

        Rectangle {
            vertical-stretch: 1;
        }

        Button {
            width: 100%;
            size: ButtonSize.lg;
            variant: ButtonVariant.primary;
            foreground: Cyber.on-neon;
            text: "+ Create identity";
            clicked => {
                GwBridge.pending-resume = { ok: false, step: 0, index: -1, draft: { funding-address: "", mnemonic: "" } };
                GwBridge.reset-entropy();
                GwBridge.roll-count = 0;
                Navigate.create-page({ });
            }
        }
    }
}
