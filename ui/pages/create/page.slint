import { Theme, UISize, ButtonSize, ButtonVariant } from "@ui/theme.slint";
import { Button } from "@ui/button.slint";
import { Input } from "@ui/input.slint";
import { Navigate } from "../../gen/navigate.slint";
import { GwBridge, IdentityDraft, SpawnOutcome, SpawnProgress } from "../../gw-bridge.slint";
import { Cyber, NeonPanel, MonoText } from "../../cyber.slint";

// On-device onboarding wizard (Architecture B). One component, a `step` property
// driving each sub-screen. The Passport mines the comet and builds + signs the
// commit+reveal itself — no host, no ticket export. Stage ints mirror
// src/store.rs::stage: 1 backed_up · 5 attested · 6 live.
export component CreatePagePage inherits Rectangle {
    background: Cyber.page-bg;

    // 1 dice · 2 write · 3 quiz · 4 fund · 5 scan-utxo · 6 spawn · 7 broadcast · 8 boot
    property <int> step: 1;
    property <IdentityDraft> draft;

    // Quiz progress + failure flag.
    property <int> quiz-pos: 0;
    property <bool> quiz-error: false;
    // Index of the persisted identity, once the backup proof passes.
    property <int> saved-index: -1;
    // Funding-UTXO entry: the typed/scanned "txid:vout:sats", the last error
    // ("" = ok), and whether one is loaded.
    property <string> funding-text: "";
    property <string> funding-msg: "";
    property <bool> funding-ready: false;
    // Result of the on-device spawn, plus the live mine state.
    property <SpawnOutcome> outcome;
    // Reveal QR stays hidden until tapped: it must not be broadcast before the
    // commit confirms, and sits too close to the commit QR to scan safely by accident.
    property <bool> reveal-shown: false;
    // Which broadcast QR is on screen: 0 = commit, 1 = reveal.
    property <int> broadcast-page: 0;
    // Go-live: whether the boot key has been written to the USB drive, and the
    // last USB export error (empty = none).
    property <bool> key-exported: false;
    property <string> usb-msg: "";
    property <bool> spawning: false;
    property <int> spawn-tries: 0;
    property <string> mine-error: "";
    // Latest mine batch result (assigned then read within one Timer tick).
    property <SpawnProgress> prog;
    // Step 2: a single tap toggles reveal for ALL 12 words; re-hidden on entry.
    property <bool> words-shown: false;
    // Snapshot of the draft's 12 words, indexed into the two-column grid. Set
    // when the draft is created/resumed (mnemonic-words() reads the Rust draft).
    property <[string]> words;

    // Clear the transient wizard state without touching a loaded draft.
    function reset-flow() {
        root.quiz-pos = 0;
        root.quiz-error = false;
        root.funding-text = "";
        root.funding-msg = "";
        root.funding-ready = false;
        root.spawning = false;
        root.spawn-tries = 0;
        root.mine-error = "";
        root.words-shown = false;
        root.reveal-shown = false;
        root.broadcast-page = 0;
        root.key-exported = false;
        root.usb-msg = "";
    }

    // Full reset for a fresh ticket (also wipes the Rust-side draft + dice pool).
    function reset-wizard() {
        GwBridge.reset-entropy();
        GwBridge.roll-count = 0;
        root.step = 1;
        root.saved-index = -1;
        reset-flow();
    }

    // Chunked miner: one batch per tick while the mine step is spawning, so the
    // UI keeps repainting and Cancel stays responsive. Slint forbids a Timer in
    // an `if`, so it lives at component scope and self-gates via `running`.
    mine-timer := Timer {
        interval: 33ms;
        running: root.step == 6 && root.spawning;
        triggered => {
            root.prog = GwBridge.spawn-poll();
            root.spawn-tries = root.prog.tries;
            if (root.prog.done) {
                root.spawning = false;
                if (root.prog.ok) {
                    root.outcome = {
                        ok: true,
                        error: "",
                        comet: root.prog.comet,
                        commit-txid: root.prog.commit-txid,
                        reveal-txid: root.prog.reveal-txid,
                        boot-command: root.prog.boot-command,
                    };
                    root.reveal-shown = false;
                    root.broadcast-page = 0;
                    root.step = 7;
                } else {
                    root.mine-error = root.prog.error;
                }
            }
        }
    }

    init => {
        if (GwBridge.pending-resume.ok) {
            // Resuming a paused identity: the draft is already rebuilt in Rust.
            root.draft = GwBridge.pending-resume.draft;
            root.words = GwBridge.mnemonic-words();
            root.saved-index = GwBridge.pending-resume.index;
            root.step = GwBridge.pending-resume.step;
            reset-flow();
            GwBridge.pending-resume = { ok: false, step: 0, index: -1, draft: { funding-address: "", mnemonic: "" } };
        } else {
            reset-wizard();
        }
    }

    VerticalLayout {
        width: parent.width;
        height: parent.height;
        padding-left: 24px;
        padding-right: 24px;
        padding-top: 20px + UISize.control-center-status-bar-height;
        padding-bottom: 20px;
        spacing: 12px;

        // ---- Step 1: dice -> mint ticket -------------------------------
        if step == 1: MonoText {
            text: "⏚ roll the dice";
            color: Cyber.neon;
            font-size: 34px;
            font-weight: 700;
            letter-spacing: 2px;
        }
        if step == 1: Text {
            text: "Roll a physical die and tap each result. 50 rolls = 128 bits.";
            color: Theme.palette-muted;
            font-family: "Montserrat";
            font-size: 22px;
            wrap: word-wrap;
        }
        if step == 1: HorizontalLayout {
            spacing: 8px;
            for face in [1, 2, 3, 4, 5, 6]: Button {
                full-width: true;
                size: ButtonSize.lg;
                variant: ButtonVariant.ghost;
                text: "\{face}";
                clicked => { GwBridge.roll-count = GwBridge.add-roll(face); }
            }
        }
        if step == 1: MonoText {
            text: "rolls  \{GwBridge.roll-count} / 50";
            color: GwBridge.roll-count >= 50 ? Cyber.neon : Theme.palette-muted;
            font-size: 22px;
            letter-spacing: 1px;
        }
        if step == 1: Rectangle {
            height: 8px;
            border-radius: 4px;
            background: Theme.palette-surface;
            border-width: 1px;
            border-color: Cyber.neon.with-alpha(0.35);
            Rectangle {
                x: 0;
                y: 0;
                width: GwBridge.roll-count >= 50 ? parent.width : parent.width * GwBridge.roll-count / 50.0;
                height: parent.height;
                border-radius: 4px;
                background: Cyber.neon;
            }
        }
        if step == 1: Rectangle { vertical-stretch: 1; }
        if step == 1: Button {
            width: 100%;
            size: ButtonSize.lg;
            variant: ButtonVariant.primary;
            foreground: Cyber.on-neon;
            disabled: GwBridge.roll-count < 50;
            text: "> Generate master ticket";
            clicked => {
                if (GwBridge.roll-count >= 50) {
                    root.draft = GwBridge.generate-identity();
                    root.words = GwBridge.mnemonic-words();
                    root.words-shown = false;
                    root.step = 2;
                }
            }
        }

        // ---- Step 2: write it down (tap to reveal all 12) --------------
        if step == 2: MonoText {
            text: "⏚ write it down";
            color: Cyber.neon;
            font-size: 34px;
            font-weight: 700;
            letter-spacing: 2px;
        }
        if step == 2: Text {
            text: "Write these 12 words on paper, in order. Lose them and this identity is gone forever. Do not photograph the screen.";
            color: Theme.palette-danger;
            font-family: "Montserrat";
            font-size: 22px;
            wrap: word-wrap;
        }
        if step == 2: Button {
            width: 100%;
            size: ButtonSize.md;
            variant: ButtonVariant.ghost;
            // Force a persistent border; the ghost variant only borders on focus.
            border-color: Cyber.neon.with-alpha(0.55);
            border-width: 1px;
            text: root.words-shown ? "Hide words" : "Tap to reveal all 12 words";
            clicked => { root.words-shown = !root.words-shown; }
        }
        // Two numbered columns (1-6 | 7-12) so the rows can be big enough to hit
        // reliably on the device; the number column is wide enough for 2 digits.
        // Six rows, each holding the left word r and the right word r+6 — Slint
        // forbids `for` inside a GridLayout, so we pair cells per row instead.
        if step == 2: VerticalLayout {
            spacing: 8px;
            for r in [0, 1, 2, 3, 4, 5]: HorizontalLayout {
                spacing: 8px;
                for c in [0, 1]: Rectangle {
                    property <int> n: r + (c == 0 ? 0 : 6);
                    horizontal-stretch: 1;
                    height: 50px;
                    border-radius: 6px;
                    background: Theme.palette-surface;
                    border-width: 1px;
                    border-color: Cyber.neon.with-alpha(0.35);
                    HorizontalLayout {
                        padding-left: 12px;
                        padding-right: 12px;
                        spacing: 10px;
                        MonoText {
                            text: "\{n + 1}";
                            color: Cyber.neon;
                            font-size: 26px;
                            vertical-alignment: center;
                            horizontal-alignment: right;
                            width: 40px;
                        }
                        MonoText {
                            text: root.words-shown ? root.words[n] : "••••";
                            color: root.words-shown ? Theme.palette-foreground : Theme.palette-muted;
                            font-size: 30px;
                            font-weight: root.words-shown ? 700 : 400;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }
        if step == 2: Button {
            width: 100%;
            size: ButtonSize.lg;
            variant: ButtonVariant.primary;
            foreground: Cyber.on-neon;
            text: "I've written all 12 down";
            clicked => {
                GwBridge.backup-reset();
                root.quiz-pos = 0;
                root.quiz-error = false;
                root.step = 3;
            }
        }
        if step == 2: Button {
            width: 100%;
            size: ButtonSize.md;
            variant: ButtonVariant.ghost;
            text: "Back";
            clicked => { root.step = 1; }
        }

        // ---- Step 3: prove the paper (quiz) ----------------------------
        if step == 3: MonoText {
            text: "⏚ prove your paper";
            color: Cyber.neon;
            font-size: 32px;
            font-weight: 700;
            letter-spacing: 2px;
        }
        if step == 3: Text {
            text: "Reading only from your paper, tap each word in order.";
            color: Theme.palette-muted;
            font-family: "Montserrat";
            font-size: 22px;
            wrap: word-wrap;
        }
        if step == 3: MonoText {
            text: "word  \{quiz-pos + 1} / 12";
            color: Cyber.neon;
            font-size: 22px;
            letter-spacing: 1px;
        }
        if step == 3: VerticalLayout {
            spacing: 8px;
            for choice in GwBridge.backup-word-choices(quiz-pos): Button {
            width: 100%;
            size: ButtonSize.md;
            variant: ButtonVariant.ghost;
            text: choice;
            clicked => {
                GwBridge.backup-tap(choice);
                if (quiz-pos == 11) {
                    if (GwBridge.confirm-backup()) {
                        root.saved-index = GwBridge.identities.length - 1;
                        GwBridge.set-stage(root.saved-index, 1);
                        root.quiz-pos = 0;
                        root.quiz-error = false;
                        root.step = 4;
                    } else {
                        root.quiz-error = true;
                        root.quiz-pos = 0;
                        GwBridge.backup-reset();
                    }
                } else {
                    root.quiz-pos += 1;
                }
            }
            }
        }
        if step == 3 && quiz-error: NeonPanel {
            accent: Theme.palette-danger;
            VerticalLayout {
                padding: 12px;
                MonoText {
                    text: "! That doesn't match your paper. Start over, reading each word carefully.";
                    color: Theme.palette-danger;
                    font-size: 21px;
                    font-weight: 600;
                }
            }
        }
        if step == 3: Button {
            width: 100%;
            size: ButtonSize.md;
            variant: ButtonVariant.ghost;
            text: "Back";
            clicked => {
                GwBridge.backup-reset();
                root.quiz-pos = 0;
                root.quiz-error = false;
                root.words-shown = false;
                root.step = 2;
            }
        }

        // ---- Step 4: fund the address ----------------------------------
        if step == 4: MonoText {
            text: "⏚ fund the address";
            color: Cyber.neon;
            font-size: 32px;
            font-weight: 700;
            letter-spacing: 2px;
        }
        if step == 4: Text {
            text: "Send Bitcoin to this address. A few thousand sats plus fees, in one payment.";
            color: Theme.palette-muted;
            font-family: "Montserrat";
            font-size: 22px;
            wrap: word-wrap;
        }
        if step == 4: HorizontalLayout {
            alignment: center;
            Image {
                source: GwBridge.address-qr();
                width: 180px;
                height: 180px;
                image-fit: contain;
            }
        }
        if step == 4: NeonPanel {
            VerticalLayout {
                padding: 12px;
                MonoText {
                    text: draft.funding-address;
                    color: Theme.palette-foreground;
                    font-size: 21px;
                    wrap: word-wrap;
                }
            }
        }
        if step == 4: Rectangle { vertical-stretch: 1; }
        if step == 4: Button {
            width: 100%;
            size: ButtonSize.lg;
            variant: ButtonVariant.primary;
            foreground: Cyber.on-neon;
            text: "I've sent the payment";
            clicked => { root.funding-msg = ""; root.funding-ready = false; root.step = 5; }
        }
        if step == 4: Button {
            width: 100%;
            size: ButtonSize.md;
            variant: ButtonVariant.ghost;
            text: "Back";
            clicked => {
                GwBridge.backup-reset();
                root.quiz-pos = 0;
                root.quiz-error = false;
                root.step = 3;
            }
        }

        // ---- Step 5: enter the funding UTXO ----------------------------
        if step == 5: MonoText {
            text: "⏚ enter the funding UTXO";
            color: Cyber.neon;
            font-size: 32px;
            font-weight: 700;
            letter-spacing: 2px;
        }
        if step == 5: Text {
            text: "Find your payment on mempool.space. Enter the output as `txid:vout:sats`, or scan a QR.";
            color: Theme.palette-muted;
            font-family: "Montserrat";
            font-size: 22px;
            wrap: word-wrap;
        }
        if step == 5: Input {
            width: 100%;
            value <=> root.funding-text;
            placeholder: "txid:vout:sats";
        }
        if step == 5: Button {
            width: 100%;
            size: ButtonSize.lg;
            variant: ButtonVariant.primary;
            foreground: Cyber.on-neon;
            text: "Continue";
            clicked => {
                root.funding-msg = GwBridge.set-funding(root.funding-text);
                if (root.funding-msg == "") {
                    GwBridge.record-funding(root.saved-index);
                    root.funding-ready = true;
                    root.step = 6;
                }
            }
        }
        if step == 5: Button {
            width: 100%;
            size: ButtonSize.md;
            variant: ButtonVariant.ghost;
            text: "Scan QR instead";
            clicked => {
                root.funding-msg = GwBridge.scan-funding();
                if (root.funding-msg == "") {
                    GwBridge.record-funding(root.saved-index);
                    root.funding-ready = true;
                    root.step = 6;
                }
            }
        }
        if step == 5 && funding-msg != "": NeonPanel {
            accent: Theme.palette-danger;
            VerticalLayout {
                padding: 12px;
                MonoText {
                    text: "! " + funding-msg;
                    color: Theme.palette-danger;
                    font-size: 21px;
                    font-weight: 600;
                }
            }
        }
        if step == 5: Rectangle { vertical-stretch: 1; }
        if step == 5: Button {
            width: 100%;
            size: ButtonSize.md;
            variant: ButtonVariant.ghost;
            text: "Back";
            clicked => { root.step = 4; }
        }

        // ---- Step 6: mine + sign on device -----------------------------
        if step == 6: MonoText {
            text: "⏚ mine & sign";
            color: Cyber.neon;
            font-size: 32px;
            font-weight: 700;
            letter-spacing: 2px;
        }
        if step == 6: Text {
            text: "Mines and signs the commit + reveal on this Passport. Keep it awake; this can take a few minutes.";
            color: Theme.palette-muted;
            font-family: "Montserrat";
            font-size: 21px;
            wrap: word-wrap;
        }
        if step == 6 && spawning: MonoText {
            text: "mining… \{spawn-tries} tries";
            color: Cyber.neon;
            font-size: 22px;
            letter-spacing: 1px;
        }
        // Indeterminate neon scanner: a block sweeping back and forth while the
        // worker thread mines. Uses `animate` (not animation-tick), so it only
        // ticks while this element exists — no continuous repaint when idle.
        if step == 6 && spawning: Rectangle {
            height: 8px;
            border-radius: 4px;
            background: Cyber.neon.with-alpha(0.15);
            clip: true;
            // Animate a plain 0..1 phase (decoupled from layout width, which is 0
            // at init) and derive the block position from it at render time.
            property <float> phase: 0;
            init => { self.phase = 1.0; }
            animate phase {
                duration: 900ms;
                easing: ease-in-out;
                iteration-count: -1;
                direction: alternate;
            }
            Rectangle {
                width: 35%;
                height: parent.height;
                border-radius: 4px;
                background: Cyber.neon;
                x: (parent.width - self.width) * parent.phase;
            }
        }
        if step == 6 && mine-error != "": NeonPanel {
            accent: Theme.palette-danger;
            VerticalLayout {
                padding: 12px;
                MonoText {
                    text: "! " + mine-error;
                    color: Theme.palette-danger;
                    font-size: 21px;
                    font-weight: 600;
                }
            }
        }
        if step == 6: Rectangle { vertical-stretch: 1; }
        if step == 6 && !spawning: Button {
            width: 100%;
            size: ButtonSize.lg;
            variant: ButtonVariant.primary;
            foreground: Cyber.on-neon;
            text: "Mine & sign on this Passport";
            clicked => {
                root.mine-error = GwBridge.spawn-begin();
                if (root.mine-error == "") {
                    root.spawn-tries = 0;
                    root.spawning = true;
                }
            }
        }
        if step == 6 && spawning: Button {
            width: 100%;
            size: ButtonSize.md;
            variant: ButtonVariant.ghost;
            text: "Cancel";
            clicked => { GwBridge.spawn-cancel(); root.spawning = false; }
        }
        if step == 6 && !spawning: Button {
            width: 100%;
            size: ButtonSize.md;
            variant: ButtonVariant.ghost;
            text: "Back";
            clicked => { root.step = 5; }
        }

        // ---- Step 7: broadcast (commit, then reveal) -------------------
        if step == 7: MonoText {
            text: "⏚ broadcast";
            color: Cyber.neon;
            font-size: 32px;
            font-weight: 700;
            letter-spacing: 2px;
        }
        if step == 7: MonoText {
            text: "comet: " + outcome.comet;
            color: Cyber.neon;
            font-size: 24px;
            wrap: word-wrap;
        }
        if step == 7: Text {
            text: "Broadcast COMMIT first on mempool.space. Wait for it to confirm, then broadcast REVEAL. Never re-run after commit.";
            color: Theme.palette-danger;
            font-family: "Montserrat";
            font-size: 21px;
            wrap: word-wrap;
        }
        // Commit and reveal are paged, one full-width QR each, so both scan large
        // and the sensitive reveal is never on screen beside the commit.
        // broadcast-page: 0 = commit (first), 1 = reveal (only after commit confirms).
        if step == 7 && broadcast-page == 0: MonoText {
            text: "commit — broadcast first";
            color: Cyber.neon;
            font-size: 22px;
        }
        // QR fills the space left between the label and the button (image-fit
        // keeps it square). Sizes to the screen; the button is always visible.
        if step == 7 && broadcast-page == 0: Rectangle {
            vertical-stretch: 1;
            Image { source: GwBridge.commit-qr(); width: 100%; height: 100%; image-fit: contain; }
        }
        if step == 7 && broadcast-page == 0: Button {
            width: 100%;
            size: ButtonSize.lg;
            variant: ButtonVariant.primary;
            foreground: Cyber.on-neon;
            text: "Next: reveal";
            clicked => { root.broadcast-page = 1; }
        }

        if step == 7 && broadcast-page == 1: MonoText {
            text: "reveal — only after commit confirms";
            color: Cyber.neon;
            font-size: 22px;
        }
        if step == 7 && broadcast-page == 1: Rectangle {
            vertical-stretch: 1;
            if reveal-shown: Image {
                source: GwBridge.reveal-qr();
                width: 100%;
                height: 100%;
                image-fit: contain;
            }
            if !reveal-shown: Rectangle {
                background: Cyber.neon.with-alpha(0.08);
                border-width: 1px;
                border-color: Cyber.neon.with-alpha(0.55);
                border-radius: 8px;
                MonoText {
                    text: "tap to reveal";
                    color: Cyber.neon;
                    font-size: 24px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
            // On top so it grabs the tap; transparent, so the QR shows through.
            TouchArea { clicked => { root.reveal-shown = !root.reveal-shown; } }
        }
        if step == 7 && broadcast-page == 1: Button {
            width: 100%;
            size: ButtonSize.md;
            variant: ButtonVariant.ghost;
            text: "← commit";
            clicked => { root.broadcast-page = 0; }
        }
        if step == 7 && broadcast-page == 1: Button {
            width: 100%;
            size: ButtonSize.lg;
            variant: ButtonVariant.primary;
            foreground: Cyber.on-neon;
            text: "Both broadcast — record it";
            clicked => {
                GwBridge.record-attestation(root.saved-index, outcome.comet, outcome.commit-txid, outcome.reveal-txid);
                root.step = 8;
            }
        }

        // ---- Step 8: boot / live ---------------------------------------
        if step == 8: MonoText {
            text: "⏚ go live";
            color: Cyber.neon;
            font-size: 32px;
            font-weight: 700;
            letter-spacing: 2px;
        }
        // Before export: transfer the boot key to a computer over USB. The key is
        // a file the user copies off the device — it is never typed.
        if step == 8 && !key-exported: Text {
            text: "Connect this Passport to your computer with USB, then copy the boot key across.";
            color: Theme.palette-muted;
            font-family: "Montserrat";
            font-size: 21px;
            wrap: word-wrap;
        }
        if step == 8 && usb-msg != "": NeonPanel {
            accent: Theme.palette-danger;
            VerticalLayout {
                padding: 12px;
                MonoText {
                    text: "! " + usb-msg;
                    color: Theme.palette-danger;
                    font-size: 21px;
                    font-weight: 600;
                }
            }
        }
        if step == 8 && !key-exported: Rectangle { vertical-stretch: 1; }
        if step == 8 && !key-exported: Button {
            width: 100%;
            size: ButtonSize.lg;
            variant: ButtonVariant.primary;
            foreground: Cyber.on-neon;
            text: "Copy boot key to USB";
            clicked => {
                root.usb-msg = GwBridge.export-boot-key();
                if (root.usb-msg == "") {
                    root.key-exported = true;
                }
            }
        }

        // After export: the key file is on the drive; show the command to run.
        if step == 8 && key-exported: MonoText {
            text: "on the USB drive: comet.feed + boot-comet.sh";
            color: Cyber.neon;
            font-size: 22px;
            wrap: word-wrap;
        }
        if step == 8 && key-exported: Text {
            text: "Run boot-comet.sh from the drive, or copy comet.feed to your computer and run:";
            color: Theme.palette-muted;
            font-family: "Montserrat";
            font-size: 21px;
            wrap: word-wrap;
        }
        if step == 8 && key-exported: NeonPanel {
            VerticalLayout {
                padding: 14px;
                // Plain Text (not MonoText) so char-wrap breaks long tokens; the
                // command is short and non-secret (the key lives in the file).
                Text {
                    text: outcome.boot-command;
                    color: Theme.palette-foreground;
                    font-family: "Source Code Pro";
                    font-size: 19px;
                    wrap: char-wrap;
                }
            }
        }
        if step == 8 && key-exported: Rectangle { vertical-stretch: 1; }
        if step == 8 && key-exported: Button {
            width: 100%;
            size: ButtonSize.lg;
            variant: ButtonVariant.primary;
            foreground: Cyber.on-neon;
            text: "My comet is live";
            clicked => {
                GwBridge.wipe-usb();
                GwBridge.set-stage(root.saved-index, 6);
                reset-wizard();
                Navigate.main-page({ });
            }
        }

        // ---- Cancel (step 1 only; later steps have their own Back) ------
        if step == 1: Button {
            width: 100%;
            size: ButtonSize.md;
            variant: ButtonVariant.ghost;
            text: "Cancel";
            clicked => { reset-wizard(); Navigate.backward(); }
        }
    }
}
