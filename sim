#!/usr/bin/env bash
# Run the KeyOS hosted simulator for groundwire — correctly.
#
# A bare `foundation sim` gets two things wrong in this environment; this handles
# both, then hands off to it (which rebuilds the app on each launch).
#
# 1. Memory cap. `foundation sim`'s keyos-kernel backs emulated RAM with the host
#    allocator (xous hosted arch -> alloc()), so it has NO in-sim ceiling. A
#    runaway grew to ~18GB anon-rss and thrashed 34GB of swap, halting the box.
#    MemorySwapMax=0 is load-bearing: no swap => no thrash => no halt. On runaway
#    it hits MemoryMax and only the sim scope is OOM-killed, leaving the rest of
#    the system healthy. Override the ceiling with SIM_MEM_MAX (e.g.
#    SIM_MEM_MAX=16G ./sim).
#
# 2. Wayland lib path. gui-server's ELF interpreter is a Nix glibc whose loader
#    doesn't read the system ld.so.cache, so its runtime dlopen of
#    libwayland-client.so.0 fails (NoWaylandLib -> emulator/window.rs:403 panic).
#    We hand it a minimal dir of symlinks to the system wayland libs on
#    LD_LIBRARY_PATH — enough for that dlopen, without the blanket /usr/lib that
#    ABI-clashes and segfaults the Nix-built kernel.
#
# 3. Window size (SIM_SCALE, default 0.93). The emulator renders a fixed 576x1072
#    device frame and pins its window non-resizable (min==max==device). Its only
#    size lever is a raw float `scale` it reads from the sim's settings.json (the
#    SetScaleFactor IPC accepts values below the simulator-cli 1x/1.5x/2x floor),
#    so we write it there before launch. Tradeoff you can't avoid here: scale 1.0
#    is crisp but 1072px tall (overflows most screens); any scale <1 downsamples
#    the finished frame, so it's smaller but progressively softer. Pick per taste
#    (0.7-0.8 is a decent sharp-ish compromise). SIM_SCALE=1 = full size.
#
#    Tried & rejected: a nested gamescope compositor to render native + downscale
#    with filtering (crisp AND small AND resizable). The emulator's winit window
#    won't initialize on gamescope — window.rs:403 panics NotSupported on both its
#    Wayland display and its XWayland (WINIT_UNIX_BACKEND=x11). Real incompat, not
#    a flag; don't re-add it. gamescope can be uninstalled; it's unused here.
set -euo pipefail

here="$(cd -- "$(dirname -- "$0")" && pwd)"
shim="$here/.wl-shim"

# Ensure the lib shim (symlinks into a git-ignored dir). ln -sf is idempotent, so
# this also self-heals when the list below grows. Delete .wl-shim to rebuild
# after a system library update. Snapshot ldconfig ONCE and match in-shell:
# piping it into `awk '...exit'` per lib makes awk close the pipe early, and
# under `pipefail`+`set -e` ldconfig's SIGPIPE aborts the whole script.
mkdir -p "$shim"
cache="$(ldconfig -p)"
for so in libwayland-client.so.0 libwayland-cursor.so.0 libwayland-egl.so.1 \
          libxkbcommon.so.0 libffi.so.8; do
  src="$(awk -v n="$so" '$1 == n { print $NF; exit }' <<<"$cache")"
  if [ -n "$src" ]; then
    ln -sf "$src" "$shim/$so"
  else
    echo "sim: warning: $so not found via ldconfig; the emulator may not start" >&2
  fi
done

# Assert the emulator window scale (see note 3); the sim persists this itself.
settings=~/.foundation/sdk/current/lib/keyos/simulator/simulator-files/settings.json
if [ -w "$settings" ] || [ -w "$(dirname "$settings")" ]; then
  printf '{"scale":%s}' "${SIM_SCALE:-0.93}" > "$settings"
else
  echo "sim: warning: can't write $settings; window scale unchanged" >&2
fi

exec systemd-run --user --scope --quiet \
  -p MemoryMax="${SIM_MEM_MAX:-12G}" \
  -p MemorySwapMax=0 \
  -- env LD_LIBRARY_PATH="$shim${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}" \
        RUSTUP_TOOLCHAIN="${RUSTUP_TOOLCHAIN:-nightly-2025-09-11}" \
     foundation sim "$@"
